{
  "name": "software-fijarap",
  "version": "1.0.0",
  "description": "Sistema de gestión para Fijarap",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "compile-electron": "tsc -p tsconfig.electron.json",
    "dev": "npm run compile-electron && concurrently \"vite\" \"npm:electron-dev\"",
    "electron-dev": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "lucide-react": "^0.376.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.6",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.fijarap.gestion",
    "productName": "Fijarap Gestión",
    "copyright": "Copyright © 2026 Fijarap",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "node_modules/sql.js/dist/sql-wasm.js"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  }
}
